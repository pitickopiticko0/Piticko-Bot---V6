# Discord forum channel, kam se mají nové počítače odesílat.
MAKEJPC_FORUM_CHANNEL_ID=123456789012345678

# Minimálně 5 minut, doporučeno 15.
MAKEJPC_CHECK_INTERVAL_MINUTES=15

# seed = při prvním spuštění pouze uloží současné produkty
# post_all = při prvním spuštění odešle všechny současné produkty
MAKEJPC_FIRST_RUN_MODE=seed

# Volitelné ID role, která se označí u nového produktu. 0 = nikoho neoznačovat.
MAKEJPC_MENTION_ROLE_ID=0
